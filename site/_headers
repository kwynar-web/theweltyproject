# Always revalidate icon assets so a renamed/updated favicon shows up
# without waiting on browser (esp. Safari) cache.
/favicon*
  Cache-Control: public, max-age=0, must-revalidate
/apple-touch*
  Cache-Control: public, max-age=0, must-revalidate
/icon-*
  Cache-Control: public, max-age=0, must-revalidate
/site.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json
/site-v8.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json
